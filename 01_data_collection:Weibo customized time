    "\n",
    "# ========== 可配置项 ==========\n",
    "# 支持多个关键词，用列表形式输入，例如：[\"加班\", \"劳动法\",\"加班费\"] \n",
    "KEYWORDS = [\"加班\"]\n",
    "HEADLESS = False                # 是否无头浏览器（可改为 False 观察浏览器）\n",
    "SCROLL_PAUSE_RANGE = (1.0, 2.2)  # 滚动/翻页随机等待范围(秒)\n",
    "ELEMENT_WAIT_SECONDS = 15        # 显式等待超时(秒)\n",
    "PAGE_MAX_FAIL = 6                # 连续翻页/滚动失败最大容忍次数\n",
    "\n",
    "# ========== 时间配置项 ==========\n",
    "\n",
    "# 抓取特定日期特定时间段\n",
    "TARGET_DATE = \"2025-01-01\"          # 目标日期\n",
    "START_HOUR = 12                      # 开始时间（0-23）\n",
    "END_HOUR = 13                        # 结束时间（1-24），END_HOUR > START_HOUR\n",
    "# 注意：微博的时间段是左闭右开区间，例如 START_HOUR=3, END_HOUR=4 表示 3:00-4:00 的数据\n",
    "\n",
    "CRAWL_FULL_DAY = False              # 设置为 True 则抓取完整一天（0-23时所有时间段）\n",
    "\n",
    "# 可选：若你有登录后 cookie，可粘贴在此（形如 \"SUB=xxx; SUBP=xxx; ...\"），请输入自己的cookie！\n",
    "MANUAL_COOKIE_STRING: Optional[str] = \"\"\n",
    "# 扫码登录最大等待时长（秒），用于给用户扫码时间\n",
    "QR_LOGIN_WAIT_SECONDS = 120\n",
    "# ===========================\n",
    "\n",
    "\n",
    "def human_pause(a=0.8, b=1.6):\n",
    "    time.sleep(random.uniform(a, b))\n",
    "\n",
    "\n",
    "def rand_in_range(r):\n",
    "    return random.uniform(r[0], r[1])\n",
    "\n",
    "\n",
    "def parse_number_from_text(text: str, keywords: List[str] = None) -> str:\n",
    "    \"\"\"\n",
    "    从文本中解析数字（支持点赞、转发、评论等）。\n",
    "    规则：支持 '赞 1.2万'、'1万+'、'1,234'、'12.3W'、'转发123'、'123转发' 等；解析失败返回 '0'\n",
    "    keywords: 需要移除的关键词列表，如 ['赞', '转发', '评论']\n",
    "    \"\"\"\n",
    "    if not text:\n",
    "        return \"0\"\n",
    "    s = text.strip()\n",
    "    \n",
    "    # 如果输入是纯数字字符串，直接返回\n",
    "    if re.match(r'^\\d+$', s):\n",
    "        return s\n",
    "    \n",
    "    # 方法1：检查是否有\"万\"单位\n",
    "    unit_match = re.search(r'(\\d+(?:\\.\\d+)?)\\s*([万Ww])', s)\n",
    "    if unit_match:\n",
    "        try:\n",
    "            num_str = unit_match.group(1)\n",
    "            num = float(num_str) * 10000\n",
    "            return str(int(num))\n",
    "        except Exception:\n",
    "            pass\n",
    "    \n",
    "    # 方法2：匹配带逗号的数字（如 1,234、12,345）\n",
    "    comma_match = re.search(r'(\\d{1,3}(?:,\\d{3})+)', s)\n",
    "    if comma_match:\n",
    "        try:\n",
    "            num_str = comma_match.group(1).replace(\",\", \"\")\n",
    "            num = float(num_str)\n",
    "            return str(int(num))\n",
    "        except Exception:\n",
    "            pass\n",
    "    \n",
    "    # 方法3：提取所有数字，取最长的（确保完整）\n",
    "    all_numbers = re.findall(r'\\d+', s)\n",
    "    if all_numbers:\n",
    "        longest_num = max(all_numbers, key=len)\n",
    "        try:\n",
    "            num = float(longest_num)\n",
    "            return str(int(num))\n",
    "        except Exception:\n",
    "            pass\n",
    "    \n",
    "    # 方法4：移除关键词后提取（兼容旧逻辑）\n",
    "    if keywords:\n",
    "        for kw in keywords:\n",
    "            s = s.replace(kw, \"\")\n",
    "    \n",
    "    # 去掉多余符号\n",
    "    s = s.replace(\"+\", \"\").replace(\",\", \"\").strip()\n",
    "    if not s:\n",
    "        return \"0\"\n",
    "\n",
    "    # 纯数字\n",
    "    if re.match(r'^\\d+$', s):\n",
    "        return s\n",
    "\n",
    "    # 常见中文/英文\"万\"单位\n",
    "    m = re.match(r\"^([0-9]+(?:\\.[0-9]+)?)\\s*[万Ww]$\", s)\n",
    "    if m:\n",
    "        try:\n",
    "            val = float(m.group(1)) * 10000\n",
    "            return str(int(val))\n",
    "        except Exception:\n",
    "            return \"0\"\n",
    "\n",
    "    # 带小数不带单位\n",
    "    m3 = re.match(r\"^([0-9]+(?:\\.[0-9]+)?)$\", s)\n",
    "    if m3:\n",
    "        try:\n",
    "            f = float(m3.group(1))\n",
    "            return str(int(f))\n",
    "        except Exception:\n",
    "            return \"0\"\n",
    "\n",
    "    # 混合文本中抽取数字与单位（兜底）\n",
    "    m4 = re.search(r\"([0-9]+(?:\\.[0-9]+)?)([万Ww]?)\", s)\n",
    "    if m4:\n",
    "        num = float(m4.group(1))\n",
    "        unit = m4.group(2)\n",
    "        if unit in [\"万\", \"W\", \"w\"]:\n",
    "            num *= 10000\n",
    "        return str(int(num))\n",
    "\n",
    "    return \"0\"\n",
    "\n",
    "\n",
    "def parse_like_to_number(text: str) -> str:\n",
    "    \"\"\"将点赞数文本解析为纯数字字符串。\"\"\"\n",
    "    return parse_number_from_text(text, keywords=[\"赞\"])\n",
    "\n",
    "\n",
    "def parse_repost_to_number(text: str) -> str:\n",
    "    \"\"\"将转发数文本解析为纯数字字符串。\"\"\"\n",
    "    return parse_number_from_text(text, keywords=[\"转发\"])\n",
    "\n",
    "\n",
    "def parse_comment_to_number(text: str) -> str:\n",
    "    \"\"\"将评论数文本解析为纯数字字符串。\"\"\"\n",
    "    return parse_number_from_text(text, keywords=[\"评论\"])\n",
    "\n",
    "\n",
    "def filter_post_content(text: str) -> str:\n",
    "    \"\"\"\n",
    "    过滤帖子内容，排除图片OCR文本、小程序文本等非用户发布的内容。\n",
    "    \"\"\"\n",
    "    if not text:\n",
    "        return \"\"\n",
    "    \n",
    "    s = text.strip()\n",
    "    \n",
    "    # 排除图片OCR相关的文本模式\n",
    "    image_ocr_patterns = [\n",
    "        r'图片\\d+',  # 图片1、图片2等\n",
    "        r'查看图片',\n",
    "        r'查看原图',\n",
    "        r'图片来自',\n",
    "        r'图\\d+',\n",
    "    ]\n",
    "    \n",
    "    # 排除小程序相关的文本\n",
    "    app_patterns = [\n",
    "        r'投票',\n",
    "        r'投票器',\n",
    "        r'小程序',\n",
    "        r'点击参与',\n",
    "        r'参与投票',\n",
    "        r'查看详情',\n",
    "        r'立即参与',\n",
    "    ]\n",
    "    \n",
    "    # 检查是否包含这些模式，如果主要是这些内容，则排除\n",
    "    image_count = sum(1 for pattern in image_ocr_patterns if re.search(pattern, s, re.IGNORECASE))\n",
    "    app_count = sum(1 for pattern in app_patterns if re.search(pattern, s, re.IGNORECASE))\n",
    "    \n",
    "    # 如果文本主要由这些内容组成，返回空\n",
    "    if image_count > 0 and len(s) < 50:\n",
    "        return \"\"\n",
    "    if app_count > 0 and len(s) < 30:\n",
    "        return \"\"\n",
    "    \n",
    "    # 移除这些模式\n",
    "    for pattern in image_ocr_patterns + app_patterns:\n",
    "        s = re.sub(pattern, '', s, flags=re.IGNORECASE)\n",
    "    \n",
    "    return s.strip()\n",
    "\n",
    "\n",
    "def clean_text(text: str) -> str:\n",
    "    \"\"\"\n",
    "    清理文本内容，移除多余空白，并过滤掉评论数、转发数、点赞数等统计信息。\n",
    "    \"\"\"\n",
    "    if not text:\n",
    "        return \"\"\n",
    "    s = re.sub(r\"\\s+\", \" \", text)\n",
    "    s = s.strip()\n",
    "    \n",
    "    # 移除常见的统计信息模式\n",
    "    # 例如：转发 123、评论 456、赞 789、转发123、评论456等\n",
    "    patterns_to_remove = [\n",
    "        r'转发\\s*\\d+(?:\\.\\d+)?[万Ww]?\\+?',  # 转发数\n",
    "        r'评论\\s*\\d+(?:\\.\\d+)?[万Ww]?\\+?',  # 评论数\n",
    "        r'赞\\s*\\d+(?:\\.\\d+)?[万Ww]?\\+?',    # 点赞数\n",
    "        r'\\d+(?:\\.\\d+)?[万Ww]?\\s*转发',    # 数字+转发\n",
    "        r'\\d+(?:\\.\\d+)?[万Ww]?\\s*评论',     # 数字+评论\n",
    "        r'\\d+(?:\\.\\d+)?[万Ww]?\\s*赞',       # 数字+赞\n",
    "    ]\n",
    "    \n",
    "    for pattern in patterns_to_remove:\n",
    "        s = re.sub(pattern, '', s, flags=re.IGNORECASE)\n",
    "    \n",
    "    # 再次清理多余空白\n",
    "    s = re.sub(r\"\\s+\", \" \", s)\n",
    "    return s.strip()\n",
    "\n",
    "\n",
