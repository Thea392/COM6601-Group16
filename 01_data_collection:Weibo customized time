    "def extract_user_info(post_element) -> Dict[str, str]:\n",
    "    \"\"\"\n",
    "    从帖子中提取用户名和发布时间。\n",
    "    根据你提供的HTML结构，用户名通常在有class=\"name\"的<a>标签中，\n",
    "    发布时间通常在class=\"from\"的div中。\n",
    "    返回格式：{\"User Name\": \"用户名\", \"Publish Time\": \"发布时间\"}\n",
    "    \"\"\"\n",
    "    result = {\"User Name\": \"\", \"Publish Time\": \"\"}\n",
    "    \n",
    "    try:\n",
    "        # 方法1：从name类提取用户名\n",
    "        name_elements = post_element.find_elements(By.CSS_SELECTOR, 'a.name')\n",
    "        for elem in name_elements:\n",
    "            try:\n",
    "                text = (elem.text or \"\").strip()\n",
    "                if text and len(text) > 0:\n",
    "                    # 获取用户名\n",
    "                    result[\"User Name\"] = text\n",
    "                    break\n",
    "            except Exception:\n",
    "                continue\n",
    "        \n",
    "        # 方法2：如果上面没找到，尝试从其他包含用户名的元素提取\n",
    "        if not result[\"User Name\"]:\n",
    "            # 查找包含\"nick-name\"属性的元素\n",
    "            nick_elements = post_element.find_elements(By.CSS_SELECTOR, '[nick-name]')\n",
    "            for elem in nick_elements:\n",
    "                try:\n",
    "                    nick_name = elem.get_attribute(\"nick-name\") or \"\"\n",
    "                    if nick_name:\n",
    "                        result[\"User Name\"] = nick_name\n",
    "                        break\n",
    "                except Exception:\n",
    "                    continue\n",
    "        \n",
    "        # 方法3：如果还没找到，尝试从用户信息区域提取\n",
    "        if not result[\"User Name\"]:\n",
    "            info_elements = post_element.find_elements(By.CSS_SELECTOR, '.info, .content, .user-info')\n",
    "            for elem in info_elements:\n",
    "                try:\n",
    "                    # 查找用户名模式：通常是纯文本，不包含特殊字符\n",
    "                    text = (elem.text or \"\").strip()\n",
    "                    # 查找可能的用户名（排除日期、时间等）\n",
    "                    lines = text.split('\\n')\n",
    "                    for line in lines:\n",
    "                        line = line.strip()\n",
    "                        if line and not re.search(r'\\d{1,2}月\\d{1,2}日|\\d{1,2}:\\d{2}|来自|转发|评论|赞', line):\n",
    "                            # 可能是用户名\n",
    "                            if len(line) < 50:  # 避免过长的文本\n",
    "                                result[\"User Name\"] = line\n",
    "                                break\n",
    "                    if result[\"User Name\"]:\n",
    "                        break\n",
    "                except Exception:\n",
    "                    continue\n",
    "        \n",
    "        # 提取发布时间\n",
    "        # 方法1：从from类提取发布时间\n",
    "        from_elements = post_element.find_elements(By.CSS_SELECTOR, '.from')\n",
    "        for elem in from_elements:\n",
    "            try:\n",
    "                text = (elem.text or \"\").strip()\n",
    "                if text:\n",
    "                    # 提取时间模式：如 \"12月04日 21:39\"\n",
    "                    time_patterns = [\n",
    "                        r'\\d{1,2}月\\d{1,2}日\\s+\\d{1,2}:\\d{2}',  # 12月04日 21:39\n",
    "                        r'\\d{4}-\\d{1,2}-\\d{1,2}\\s+\\d{1,2}:\\d{2}',  # 2025-01-01 10:30\n",
    "                        r'今天\\s+\\d{1,2}:\\d{2}',  # 今天 10:30\n",
    "                        r'昨天\\s+\\d{1,2}:\\d{2}',  # 昨天 10:30\n",
    "                    ]\n",
    "                    \n",
    "                    for pattern in time_patterns:\n",
    "                        time_match = re.search(pattern, text)\n",
    "                        if time_match:\n",
    "                            result[\"Publish Time\"] = time_match.group()\n",
    "                            break\n",
    "                    \n",
    "                    # 如果没找到模式匹配，但文本包含时间信息，直接使用\n",
    "                    if not result[\"Publish Time\"] and any(keyword in text for keyword in [\"月\", \"日\", \"今天\", \"昨天\", \":\", \"分钟前\", \"小时前\"]):\n",
    "                        # 提取前20个字符作为时间信息\n",
    "                        time_part = text[:50].strip()\n",
    "                        result[\"Publish Time\"] = time_part\n",
    "                    break\n",
    "            except Exception:\n",
    "                continue\n",
    "        \n",
    "        # 方法2：如果from类没找到，尝试从其他元素中找时间\n",
    "        if not result[\"Publish Time\"]:\n",
    "            time_elements = post_element.find_elements(By.CSS_SELECTOR, 'a[target=\"_blank\"], span.time, .time')\n",
    "            for elem in time_elements:\n",
    "                try:\n",
    "                    text = (elem.text or \"\").strip()\n",
    "                    if text:\n",
    "                        # 检查是否包含时间模式\n",
    "                        if any(keyword in text for keyword in [\"月\", \"日\", \":\", \"今天\", \"昨天\"]):\n",
    "                            result[\"Publish Time\"] = text\n",
    "                            break\n",
    "                except Exception:\n",
    "                    continue\n",
    "        \n",
    "        # 方法3：从链接的文本中提取时间\n",
    "        if not result[\"Publish Time\"]:\n",
    "            all_links = post_element.find_elements(By.CSS_SELECTOR, 'a')\n",
    "            for link in all_links:\n",
    "                try:\n",
    "                    text = (link.text or \"\").strip()\n",
    "                    href = (link.get_attribute(\"href\") or \"\").strip()\n",
    "                    \n",
    "                    # 如果链接文本包含时间模式\n",
    "                    if text and any(keyword in text for keyword in [\"月\", \"日\", \":\", \"今天\", \"昨天\"]):\n",
    "                        result[\"Publish Time\"] = text\n",
    "                        break\n",
    "                    \n",
    "                    # 如果链接是时间链接（包含weibo.com和时间戳）\n",
    "                    if \"weibo.com\" in href and (\"/status/\" in href or \"time=\" in href):\n",
    "                        # 从URL参数中提取时间\n",
    "                        parsed_url = urllib.parse.urlparse(href)\n",
    "                        query_params = urllib.parse.parse_qs(parsed_url.query)\n",
    "                        if \"t\" in query_params:\n",
    "                            timestamp = query_params[\"t\"][0]\n",
    "                            try:\n",
    "                                # 将时间戳转换为可读时间\n",
    "                                dt = datetime.datetime.fromtimestamp(int(timestamp))\n",
    "                                result[\"Publish Time\"] = dt.strftime(\"%Y-%m-%d %H:%M\")\n",
    "                            except:\n",
    "                                pass\n",
    "                        break\n",
    "                except Exception:\n",
    "                    continue\n",
    "    \n",
    "    except Exception as e:\n",
    "        # 静默处理错误\n",
    "        pass\n",
    "    \n",
    "    return result\n",
