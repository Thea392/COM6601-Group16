    "def inject_manual_cookie_if_any(driver: webdriver.Chrome):\n",
    "    if not MANUAL_COOKIE_STRING:\n",
    "        return\n",
    "    try:\n",
    "        # 先打开域以便写入 cookie\n",
    "        driver.get(\"https://www.weibo.com/\")\n",
    "        human_pause(1.2, 2.0)\n",
    "        # 解析 cookie 字符串\n",
    "        parts = [p.strip() for p in MANUAL_COOKIE_STRING.split(\";\") if \"=\" in p]\n",
    "        for p in parts:\n",
    "            name, value = p.split(\"=\", 1)\n",
    "            driver.add_cookie({\"name\": name.strip(), \"value\": value.strip(), \"domain\": \".weibo.com\"})\n",
    "        driver.get(\"https://www.weibo.com/\")\n",
    "        human_pause(1.0, 1.6)\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "\n",
    "def wait_for_manual_login(driver: webdriver.Chrome, max_seconds: int) -> bool:\n",
    "    \"\"\"\n",
    "    轮询等待用户完成扫码登录：\n",
    "    - 判断依据：是否出现 weibo 的会话 Cookie（常见为 SUB）。\n",
    "    - 返回 True 表示检测到登录；False 表示超时未检测到。\n",
    "    \"\"\"\n",
    "    deadline = time.time() + max_seconds\n",
    "    last_hint = 0.0\n",
    "    last_refresh = 0.0\n",
    "    while time.time() < deadline:\n",
    "        try:\n",
    "            # 检查 weibo.com 域 Cookie（包含 SUB 视为已登录）\n",
    "            for c in driver.get_cookies():\n",
    "                name = (c.get(\"name\") or \"\").upper()\n",
    "                if name in (\"SUB\", \"SUBP\"):\n",
    "                    return True\n",
    "        except Exception:\n",
    "            pass\n",
    "\n",
    "        # 每 10 秒刷新一次首页，帮助同步跨域设置的 Cookie\n",
    "        now = time.time()\n",
    "        if now - last_refresh > 10:\n",
    "            last_refresh = now\n",
    "            try:\n",
    "                driver.get(\"https://www.weibo.com/\")\n",
    "            except Exception:\n",
    "                pass\n",
    "            time.sleep(1.0)\n",
    "\n",
    "        # 每 5 秒在控制台提示一次\n",
    "        if now - last_hint > 5:\n",
    "            last_hint = now\n",
    "            print(\"等待扫码登录中...（剩余约 %ds）\" % int(deadline - now))\n",
    "        time.sleep(1.5)\n",
    "    return False\n",
    "\n",
    "\n",
    "def is_logged_in(driver: webdriver.Chrome) -> bool:\n",
    "    \"\"\"通过是否存在 SUB Cookie 粗略判断已登录。\"\"\"\n",
    "    try:\n",
    "        for c in driver.get_cookies():\n",
    "            if (c.get(\"name\") or \"\").upper() in (\"SUB\", \"SUBP\"):\n",
    "                return True\n",
    "    except Exception:\n",
    "        pass\n",
    "    return False\n",
    "\n",
    "\n",
    "def try_homepage_search(driver: webdriver.Chrome, keyword: str) -> bool:\n",
    "    \"\"\"\n",
    "    在 weibo.com 首页使用搜索框输入关键词并提交。\n",
    "    返回：True 表示已触发跳转到搜索结果页；False 则让上层走备用方案。\n",
    "    \"\"\"\n",
    "    try:\n",
    "        driver.get(\"https://www.weibo.com/\")\n",
    "        WebDriverWait(driver, ELEMENT_WAIT_SECONDS).until(\n",
    "            EC.presence_of_element_located((By.TAG_NAME, \"body\"))\n",
    "        )\n",
    "        human_pause()\n",
    "\n",
    "        # 可能出现的登录弹层/同意按钮，尽量忽略失败\n",
    "        try:\n",
    "            # 关闭可能的弹窗按钮\n",
    "            close_btns = driver.find_elements(By.CSS_SELECTOR, '[aria-label*=\"关闭\"], [title*=\"关闭\"], .woo-dialog-actions .woo-button-main')\n",
    "            if close_btns:\n",
    "                for b in close_btns[:2]:\n",
    "                    try:\n",
    "                        b.click()\n",
    "                        human_pause(0.4, 0.8)\n",
    "                    except Exception:\n",
    "                        pass\n",
    "        except Exception:\n",
    "            pass\n",
    "\n",
    "        # 寻找搜索框（多套选择器以适配不同版本）\n",
    "        candidates = [\n",
    "            'input[placeholder*=\"搜索\"]',\n",
    "            'input[type=\"search\"]',\n",
    "            '[data-testid=\"search-input\"] input',\n",
    "            'input.suggest-input',\n",
    "        ]\n",
    "        search_input = None\n",
    "        for css in candidates:\n",
    "            elems = driver.find_elements(By.CSS_SELECTOR, css)\n",
    "            if elems:\n",
    "                search_input = elems[0]\n",
    "                break\n",
    "        if not search_input:\n",
    "            return False\n",
    "\n",
    "        ActionChains(driver).move_to_element(search_input).pause(0.3).click().perform()\n",
    "        human_pause(0.2, 0.5)\n",
    "        search_input.clear()\n",
    "        for ch in keyword:\n",
    "            search_input.send_keys(ch)\n",
    "            time.sleep(random.uniform(0.05, 0.12))  # 模拟人输入\n",
    "\n",
    "        # 提交搜索（Enter 或点击搜索按钮）\n",
    "        search_input.submit()\n",
    "        human_pause(1.2, 1.8)\n",
    "\n",
    "        # 等待跳转到搜索结果（weibo.com 新版常跳转到 s.weibo.com）\n",
    "        WebDriverWait(driver, ELEMENT_WAIT_SECONDS).until(\n",
    "            EC.url_contains(\"weibo.com\")  # 容忍 s.weibo.com 与 weibo.com\n",
    "        )\n",
    "        return True\n",
    "    except Exception:\n",
    "        return False\n",
    "\n",
    "\n",
    "def goto_search_result_by_hour(driver: webdriver.Chrome, keyword: str, hour_start: int, hour_end: int):\n",
    "    \"\"\"\n",
    "    直达 s.weibo.com 的搜索结果页，按小时区间搜索\n",
    "    hour_start: 开始小时 (0-23)\n",
    "    hour_end: 结束小时 (1-24)，hour_end > hour_start\n",
    "    \"\"\"\n",
    "    # 对关键词进行URL编码\n",
    "    encoded_keyword = urllib.parse.quote(keyword)\n",
    "    # 构造日期范围，格式：custom:2025-01-01-0:2025-01-01-1\n",
    "    date_scope = f\"custom:{TARGET_DATE}-{hour_start}:{TARGET_DATE}-{hour_end}\"\n",
    "    encoded_date_scope = urllib.parse.quote(date_scope)\n",
    "    url = f\"https://s.weibo.com/weibo?q={encoded_keyword}&typeall=1&suball=1&timescope={encoded_date_scope}&Refer=g\"\n",
    "    print(f\"搜索URL（{hour_start:02d}:00-{hour_end:02d}:00）: {url}\")\n",
    "    driver.get(url)\n",
    "    WebDriverWait(driver, ELEMENT_WAIT_SECONDS).until(\n",
    "        EC.presence_of_element_located((By.TAG_NAME, \"body\"))\n",
    "    )\n",
    "    human_pause(1.0, 1.6)\n",
    "\n",
    "\n",
    "def goto_search_result_cross_day(driver: webdriver.Chrome, keyword: str):\n",
    "    \"\"\"\n",
    "    搜索跨日数据：23时-0时（第二天0时）\n",
    "    \"\"\"\n",
    "    # 计算第二天的日期\n",
    "    try:\n",
    "        target_date_obj = datetime.datetime.strptime(TARGET_DATE, \"%Y-%m-%d\")\n",
    "        next_day_obj = target_date_obj + datetime.timedelta(days=1)\n",
    "        next_day_str = next_day_obj.strftime(\"%Y-%m-%d\")\n",
    "    except Exception:\n",
    "        next_day_str = TARGET_DATE  # 如果解析失败，使用同一天\n",
    "    \n",
    "    # 对关键词进行URL编码\n",
    "    encoded_keyword = urllib.parse.quote(keyword)\n",
    "    # 构造跨日日期范围，格式：custom:2025-01-01-23:2025-01-02-0\n",
    "    date_scope = f\"custom:{TARGET_DATE}-23:{next_day_str}-0\"\n",
    "    encoded_date_scope = urllib.parse.quote(date_scope)\n",
    "    url = f\"https://s.weibo.com/weibo?q={encoded_keyword}&typeall=1&suball=1&timescope={encoded_date_scope}&Refer=g\"\n",
    "    print(f\"搜索URL（跨日 {TARGET_DATE} 23:00-{next_day_str} 00:00）: {url}\")\n",
    "    driver.get(url)\n",
    "    WebDriverWait(driver, ELEMENT_WAIT_SECONDS).until(\n",
    "        EC.presence_of_element_located((By.TAG_NAME, \"body\"))\n",
    "    )\n",
    "    human_pause(1.0, 1.6)\n",
    "\n",
    "\n",
    "def is_result_page(driver: webdriver.Chrome) -> bool:\n",
    "    u = driver.current_url\n",
    "    return (\"s.weibo.com/weibo\" in u) or (\"search\" in u) or (\"weibo.com\" in u and \"q=\" in u)\n",
    "\n",
    "\n",
    "def extract_interaction_numbers(post_element) -> Dict[str, str]:\n",
    "    \"\"\"\n",
