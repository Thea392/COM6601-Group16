    "def scroll_or_next_page(driver: webdriver.Chrome) -> bool:\n",
    "    \"\"\"\n",
    "    优先尝试滚动加载；若发现\"下一页\"按钮则尝试点击翻页。\n",
    "    返回 True 表示尝试了加载动作（无论是否成功），False 表示无法继续。\n",
    "    \"\"\"\n",
    "    try:\n",
    "        # s.weibo.com 常见\"下一页\"\n",
    "        next_btns = driver.find_elements(By.CSS_SELECTOR, \"a.next, a.next_page, a[title='下一页']\")\n",
    "        for nb in next_btns:\n",
    "            if nb.is_displayed() and nb.is_enabled():\n",
    "                try:\n",
    "                    driver.execute_script(\"arguments[0].scrollIntoView({block:'center'});\", nb)\n",
    "                    human_pause(0.6, 1.2)\n",
    "                    nb.click()\n",
    "                    human_pause(*SCROLL_PAUSE_RANGE)\n",
    "                    return True\n",
    "                except Exception:\n",
    "                    continue\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "    # 滚动到底部\n",
    "    try:\n",
    "        last_height = driver.execute_script(\"return document.body.scrollHeight\")\n",
    "        driver.execute_script(\"window.scrollTo(0, document.body.scrollHeight);\")\n",
    "        time.sleep(rand_in_range(SCROLL_PAUSE_RANGE))\n",
    "        new_height = driver.execute_script(\"return document.body.scrollHeight\")\n",
    "        return new_height > last_height\n",
    "    except Exception:\n",
    "        return False\n",
    "\n",
