    "def is_repost_post(post_element) -> bool:\n",
    "    \"\"\"\n",
    "    检测帖子是否是转发帖。\n",
    "    返回 True 表示是转发帖，False 表示是原帖。\n",
    "    \"\"\"\n",
    "    try:\n",
    "        # 方法1：检查是否有转发相关的CSS类或属性\n",
    "        # s.weibo.com 转发帖可能有特殊标识\n",
    "        repost_indicators = post_element.find_elements(By.CSS_SELECTOR, \n",
    "            '[class*=\"repost\"], [class*=\"forward\"], [node-type=\"feed_list_forwardContent\"], .card-comment')\n",
    "        if repost_indicators:\n",
    "            # 进一步确认：检查是否包含转发内容区域\n",
    "            for indicator in repost_indicators:\n",
    "                indicator_text = indicator.text.strip().lower()\n",
    "                if any(kw in indicator_text for kw in [\"转发\", \"//@\", \"转发了\"]):\n",
    "                    return True\n",
    "        \n",
    "        # 方法2：检查文本内容是否包含转发标识\n",
    "        # 获取主要文本内容\n",
    "        try:\n",
    "            main_text = \"\"\n",
    "            # 优先从p.txt获取（s.weibo.com结构）\n",
    "            text_nodes = post_element.find_elements(By.CSS_SELECTOR, \"p.txt\")\n",
    "            if text_nodes:\n",
    "                main_text = text_nodes[0].text.strip()\n",
    "            else:\n",
    "                # 尝试其他文本容器\n",
    "                text_nodes = post_element.find_elements(By.CSS_SELECTOR, \"p, div[dir='auto'], span\")\n",
    "                if text_nodes:\n",
    "                    main_text = text_nodes[0].text.strip()\n",
    "                else:\n",
    "                    main_text = post_element.text.strip()\n",
    "            \n",
    "            main_text_lower = main_text.lower()\n",
    "            \n",
    "            # 检查是否以转发标识开头（转发帖的典型特征）\n",
    "            if main_text.startswith(\"转发\") or main_text.startswith(\"//@\"):\n",
    "                return True\n",
    "            \n",
    "            # 检查是否包含\"//@\"模式（转发帖的典型特征：//@用户名）\n",
    "            if re.search(r'//@\\w+', main_text):\n",
    "                return True\n",
    "            \n",
    "            # 检查是否包含\"转发微博\"等关键词（在文本开头或特定位置）\n",
    "            repost_patterns = [\n",
    "                r'^转发\\s*微博',\n",
    "                r'^转发了',\n",
    "                r'转发\\s*自',\n",
    "                r'//@\\w+',  # 再次确认\n",
    "            ]\n",
    "            for pattern in repost_patterns:\n",
    "                if re.search(pattern, main_text, re.IGNORECASE):\n",
    "                    return True\n",
    "        except Exception:\n",
    "            pass\n",
    "        \n",
    "        # 方法3：检查整个元素的文本（作为兜底）\n",
    "        try:\n",
    "            full_text = post_element.text.strip().lower()\n",
    "            # 如果文本中包含明显的转发标识\n",
    "            if any(keyword in full_text for keyword in [\"转发微博\", \"//@\", \"转发了\"]):\n",
    "                # 进一步确认：检查是否在文本开头或特定位置\n",
    "                if re.search(r'^(转发|//@)', full_text, re.MULTILINE):\n",
    "                    return True\n",
    "        except Exception:\n",
    "            pass\n",
    "        \n",
    "        return False\n",
    "    except Exception:\n",
    "        # 如果检测失败，默认认为是原帖（保守策略，避免误过滤）\n",
    "        return False\n",
