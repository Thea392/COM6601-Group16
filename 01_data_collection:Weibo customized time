    "                                    driver.execute_script(\"arguments[0].scrollIntoView({block:'center', behavior:'smooth'});\", elem)\n",
    "                                    human_pause(0.2, 0.4)\n",
    "                                    elem.click()\n",
    "                                    found_any = True\n",
    "                                    expanded_count += 1\n",
    "                                    human_pause(0.5, 0.8)\n",
